# Environment example

# Optional. Used by the autoplayer LLM planner when calling an OpenAI-compatible endpoint.
# The app never writes or exposes these values in the web UI.
# MINDCRAFT_LLM_API_KEY=
# DEEPSEEK_API_KEY=
# DASHSCOPE_API_KEY=
# QWEN_API_KEY=
# ARK_API_KEY=
# VOLCENGINE_API_KEY=
# DOUBAO_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=

# Optional. Defaults are configured in the web UI.
# MINECRAFT_SERVER_DIR=C:\path\to\minecraft-server
# MINDCRAFT_LLM_PROVIDER=deepseek
# MINDCRAFT_LLM_BASE_URL=https://api.deepseek.com
# MINDCRAFT_LLM_MODEL=deepseek-v4-flash
# MINDCRAFT_AUTOPLAYER_PORT=4177
# Optional. Keep false unless CoPaw/streamer tools run on another LAN machine.
# MINDCRAFT_MCP_ALLOW_LAN=false
