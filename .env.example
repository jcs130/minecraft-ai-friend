# Environment example

# Optional. Used by the autoplayer LLM planner when calling an OpenAI-compatible endpoint.
# MINDCRAFT_LLM_API_KEY=
# DEEPSEEK_API_KEY=

# Optional. Defaults are configured in the web UI.
# MINECRAFT_SERVER_DIR=C:\path\to\minecraft-server
# MINDCRAFT_LLM_BASE_URL=https://api.deepseek.com
# MINDCRAFT_LLM_MODEL=deepseek-v4-flash
# MINDCRAFT_AUTOPLAYER_PORT=4177
